# =========================
# MODEL
# =========================
DEFAULT_MODEL=qwen3:4b
EMBEDDING_MODEL=nomic-embed-text

# =========================
# PIPELINE
# =========================
MAX_CRITIC_RETRIES=2
MAX_REFLECT_RETRIES=1
MAX_EXECUTOR_STEPS=10
COMPRESS_THRESHOLD=50
KEEP_RECENT_MESSAGES=20

# =========================
# WEB SEARCH PROVIDERS
# Urutan = prioritas fallback. Semua provider di bawah tidak butuh API key.
# Provider tersedia: duckduckgo, brave, bing
# Untuk aktifkan Brave API / Tavily API: uncomment kode di providers/brave.py dan providers/tavily.py
# =========================
SEARCH_PROVIDERS=duckduckgo,brave,bing
SEARCH_FALLBACK=true

# Brave Search API (opsional, jika ingin pakai API resmi)
# BRAVE_API_KEY=

# Tavily API (opsional, jika ingin pakai API resmi)
# TAVILY_API_KEY=

# =========================
# CLICKUP API
# Dapatkan API key di: https://app.clickup.com/settings/apps
# Workspace ID: jalankan program, ketik "lihat workspace clickup"
# =========================
CLICKUP_API_KEY=pk_your_api_key_here
CLICKUP_WORKSPACE_ID=your_workspace_id_here
CLICKUP_CACHE_TTL=300
